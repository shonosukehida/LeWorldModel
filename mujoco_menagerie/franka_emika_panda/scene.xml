<!-- カメラ位置(0.4, 0, 0.15) -->
<mujoco model="panda scene">
  <include file="panda.xml"/>

  <option timestep="0.001" gravity="0 0 -9.81" iterations="100" cone="elliptic" />
  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="brown_floor" rgba="0.302 0.161 0.102 1" reflectance="0.0" specular="0.05" shininess="0.1"/>
    <material name="start_marker" rgba="1 0 0 0"/>     <!-- 赤 -->
    <material name="goal_marker" rgba="0 1 0 0"/>      <!-- 緑 -->
    <material name="black_wall" rgba="0 0 0 0"/> <!-- 黒い壁 -->
  </asset>

  <worldbody>
    <camera name="top_view" pos="0.5 0 1.3" xyaxes="0 -1 0 1 0 0"/>
    <camera name="diagonal_view" pos="0.5 -0.4 0.7" xyaxes="0 -0.8 -0.6   1 0 0"  fovy="70"/>

    <camera name="shoulder" pos="0.4 0.0 0.2" xyaxes="1 0 0 0 0 1"/>
    <camera name="top_reverse" pos="1.3 0.0 0.7" xyaxes="0 1 0  -1 0 1.2"/>

    <light pos="0 0 2.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="brown_floor" friction="0.4 0.15 0.01" contype="7" conaffinity="7"/>


    <!-- 柵（黒い壁） -->
    <geom name="wall_bottom"  type="box" pos="-0.685 0.0 5" size="1 0.2 5" material="black_wall" contype="2" conaffinity="4"/>
    <geom name="wall_top" type="box" pos="1.715 0.0 5"  size="1 0.2 5" material="black_wall" contype="2" conaffinity="4"/>
    <geom name="wall_right" type="box" pos="0.0 -1.2 5" size="3 1 5" material="black_wall" contype="2" conaffinity="4"/>
    <geom name="wall_left"    type="box" pos="0.0  1.2 5" size="3 1 5" material="black_wall" contype="2" conaffinity="4"/> 

    <!-- Start marker -->
    <geom name="start_marker" type="cylinder" size="0.06 0.000001" pos="0.0 -0.3 0.05" material="start_marker" contype="0" conaffinity="0"/>

    <!-- Goal marker -->
    <geom name="goal_marker" type="cylinder" size="0.06 0.000001" pos="0.5 0.3 0.05" material="goal_marker" contype="0" conaffinity="0"/>

    <!-- Blue box (movable object) -->
    <body name="blue_box" pos="0.0 -0.3 0.1">
      <inertial pos="0 0 0" mass="10" diaginertia="0.05 0.05 0.05"/>
      <geom name="blue_box" type="box" size="0.05 0.05 0.05" rgba="0 0 0.7 1" contype="4" conaffinity="3" friction="0.4 0.15 0.01"/> 
      <joint name="free_joint_blue_box" type="free"/>
    </body>
  </worldbody>
</mujoco>
